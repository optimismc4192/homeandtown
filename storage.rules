rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // 누구나 이미지를 볼 수 있습니다.
      allow read: if true;
      
      // 누구나 이미지를 업로드할 수 있습니다. (매물 등록용)
      // 단, 수정/삭제는 로그인한 관리자만 가능하도록 설정할 수도 있지만,
      // 일단 업로드를 위해 write 권한을 모두에게 엽니다.
      allow write: if true;
    }
  }
}
